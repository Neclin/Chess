# Unity-generated directories — regenerated on open, never commit.
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta files must accompany their asset; only ignore .meta when the asset itself is ignored.
!/[Aa]ssets/**/*.meta

# Auto-generated Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# IDE / editor caches
.vs/
.vscode/
.idea/
.gradle/

# Auto-generated solution & project files (Unity rewrites these on open)
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity meta files for the auto-generated artefacts above
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash reports
sysinfo.txt

# Build artefacts
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Auto-generated Android streaming assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS noise
.DS_Store
Thumbs.db
desktop.ini
